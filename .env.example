# ================================
# AI Learning Coach 环境配置示例
# ================================
# 请复制此文件为 .env 并修改相应配置

# ================================
# 应用基础配置
# ================================
PROJECT_NAME=AI Learning Coach
ENVIRONMENT=production
DEBUG=false

# ================================
# 数据库配置 (PostgreSQL)
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ai_learning_coach
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your_strong_password_here@db:5432/ai_learning_coach

# ================================
# Redis 配置
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================================
# Milvus 向量数据库配置
# ================================
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ================================
# JWT Token 配置
# ================================
SECRET_KEY=your_jwt_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=30

# ================================
# AI 模型配置 (OpenAI API)
# ================================
# 请填写您的 OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 或使用兼容的其他服务
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ================================
# Celery 配置 (异步任务)
# ================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ================================
# CORS 配置
# ================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000"]

# ================================
# 日志配置
# ================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ================================
# 邮件配置 (可选)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@ailearningcoach.com

# ================================
# MinIO 配置 (Milvus 存储)
# ================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ================================
# 安全配置
# ================================
# 是否启用API限流
RATE_LIMIT_ENABLED=true
# 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60

# ================================
# 开发配置 (仅开发环境)
# ================================
# 是否自动重载
AUTO_RELOAD=true
# 是否显示详细错误信息
SHOW_ERROR_DETAILS=false

# ================================
# Deep Research
# ================================
DASHSCOPE_API_KEY=your_dashscope_api_key
TAVILY_API_KEY=your_tavily_api_key
BOCHA_API_KEY=your_bocha_api_key
